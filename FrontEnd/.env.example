# Copy to `.env` in this folder:  cp .env.example .env
# Restart `npm run dev` after changing values (Vite reads env at startup).

# Supabase project URL (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/public key — safe in the browser; RLS enforces access (same key as Worker uses for user JWT)
VITE_SUPABASE_ANON_KEY=your-anon-key

# CRM API (Cloudflare Worker local dev — run `npm run dev` in BackEnd/Crm.Api)
VITE_API_BASE_URL=http://127.0.0.1:8787
